---
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationCard from "../components/PublicationCard.astro";
import { getCollection } from "astro:content";
import { authorshipOverrides } from "../data/authorshipOverrides";

const publications = await getCollection("publications");
const pageTitle = "Publications";
const hasSharedFirst = publications.some(
  (p) => p.data.doi && authorshipOverrides[p.data.doi]?.sharedFirst
);
const hasSharedLast = publications.some(
  (p) => p.data.doi && authorshipOverrides[p.data.doi]?.sharedLast
);
---

<BaseLayout pageTitle={pageTitle}>
  <div class="pub-list">
    {
      publications.map((pub) => (
        <PublicationCard
          title={pub.data.title}
          authors={pub.data.authors}
          journal={pub.data.journal}
          year={pub.data.year}
          doi={pub.data.doi}
        />
      ))
    }
  </div>
  {(hasSharedFirst || hasSharedLast) && (
    <p class="footnote">
      {hasSharedFirst && <span><sup>1</sup> Shared first authorship.</span>}
      {hasSharedLast && <span><sup>2</sup> Shared last authorship.</span>}
    </p>
  )}
  <style>
    .pub-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 1rem;
    }

    .footnote {
      font-size: 0.78rem;
      color: #888;
      margin-top: 1.5rem;
      display: flex;
      gap: 1rem;
    }

    :global(.dark) .footnote {
      color: #999;
    }
  </style>
</BaseLayout>
