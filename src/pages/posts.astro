---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import NotebookCard from "../components/NotebookCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = "Posts";
---

<BaseLayout pageTitle={pageTitle}>
  <p>
    The posts are more text-heavy and the notebooks are more focused on code.
  </p>
  <h2>Writing</h2>
  <p>A mix of Julia, R and rheumatology.</p>
  <div class="post-grid">
    {posts.map((post) => (
      <PostCard
        url={`/posts/${post.id}`}
        title={post.data.title}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
      />
    ))}
  </div>
  <h2>Notebooks</h2>
  <p>Richard McElreath's statistical rethinking online lectures in Julia:</p>
  <div class="post-grid">
    <NotebookCard
      url="https://learnbayes.se/julia/statistical_rethinking/02_globetossing"
      title="Lecture 2: The Garden of Forking Paths"
      description="Description placeholder"
      tags={[]}
    />
    <NotebookCard
      url="https://learnbayes.se/julia/statistical_rethinking/03_geocentric.html"
      title="Lecture 3: Geocentric Models"
      description="Description placeholder"
      tags={[]}
    />
    <NotebookCard
      url="https://learnbayes.se/julia/statistical_rethinking/04_categories.html"
      title="Lecture 4: Categories and Curves"
      description="Description placeholder"
      tags={[]}
    />
    <NotebookCard
      url="https://learnbayes.se/julia/statistical_rethinking/05_confounds.html"
      title="Lecture 5: Elemental Confounds"
      description="Description placeholder"
      tags={[]}
    />
    <NotebookCard
      url="https://learnbayes.se/julia/statistical_rethinking/06_docalculus.html"
      title="Lecture 6: Good and Bad Controls"
      description="Description placeholder"
      tags={[]}
    />
  </div>
  <p>
    Some <a href="https://turinglang.org" target="_blank">Turing.jl</a> models:
  </p>
  <div class="post-grid">
    <NotebookCard
      url="https://learnbayes.se/julia/linearregression.html"
      title="Learn about Turing.jl with a linear regression"
      description="Description placeholder"
      tags={[]}
    />
    <NotebookCard
      url="https://learnbayes.se/julia/metaanalysis.html"
      title="Basic tutorial on Meta Analysis"
      description="Description placeholder"
      tags={[]}
    />
    <NotebookCard
      url="https://learnbayes.se/julia/hmm.html"
      title="Intro to Hidden Markov Models"
      description="Description placeholder"
      tags={[]}
    />
  </div>
  <style>
    .post-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-top: 1rem;
    }

    @media (max-width: 900px) {
      .post-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
